# STT API 키 — 실제 값은 .env에 작성 (.env는 gitignore됨)

# Naver Clova Speech
CLOVA_INVOKE_URL=
CLOVA_SECRET_KEY=

# Vito (리턴제로)
VITO_CLIENT_ID=
VITO_CLIENT_SECRET=

# Google Cloud Speech-to-Text
GOOGLE_APPLICATION_CREDENTIALS=  # 서비스계정 JSON 파일 경로
GCP_PROJECT_ID=

# Amazon Transcribe
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=  # Transcribe 입력용 버킷
